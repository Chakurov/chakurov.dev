---
const projects = [
  {
    title: "Project One",
    description: "Coming soon — a real project goes here.",
    tags: ["tag", "tag"],
    link: "#",
  },
  {
    title: "Project Two",
    description: "Coming soon.",
    tags: ["tag"],
    link: "#",
  },
  {
    title: "Project Three",
    description: "Coming soon.",
    tags: ["tag", "tag"],
    link: "#",
  },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Ivan Chakurov — building digital products and tools." />
		<title>Ivan Chakurov</title>
	</head>
	<body>
		<main>
			<section class="hero">
				<h1>Ivan Chakurov</h1>
				<p class="tagline">Building digital products, tools, and experiments.</p>
				<p class="subtag">Technician by day. Builder by night. Relocating to opportunity by December.</p>
			</section>

			<section class="about">
				<h2>About</h2>
				<p>
					Technician at Vanderlande, transitioning out by end of 2026. Background in
					digital marketing and e-commerce. Now shipping my own projects — small,
					sharp, and aimed at real problems.
				</p>
			</section>

			<section class="projects">
				<h2>Projects</h2>
				<div class="grid">
					{projects.map((p) => (
						<a href={p.link} class="card">
							<h3>{p.title}</h3>
							<p>{p.description}</p>
							<div class="tags">
								{p.tags.map((t) => <span class="tag">{t}</span>)}
							</div>
						</a>
					))}
				</div>
				<p class="note">More projects shipping soon. Watch this space.</p>
			</section>

			<section class="contact">
				<h2>Contact</h2>
				<p>
					Email: <a href="mailto:ivan@chakurov.dev">ivan@chakurov.dev</a>
				</p>
				<p>
					GitHub: <a href="https://github.com/Chakurov" target="_blank" rel="noopener">github.com/Chakurov</a>
				</p>
			</section>

			<footer>
				<p>© 2026 Ivan Chakurov</p>
			</footer>
		</main>

		<style>
			:root {
				--bg: #0a0a0a;
				--fg: #fafafa;
				--muted: #a0a0a0;
				--accent: #7c3aed;
				--card: #141414;
				--border: #262626;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { background: var(--bg); color: var(--fg); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; }
			main { max-width: 720px; margin: 0 auto; padding: 4rem 1.5rem; }
			section { margin-bottom: 4rem; }
			h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
			h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
			h3 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
			.tagline { font-size: 1.25rem; color: var(--fg); margin-bottom: 0.5rem; }
			.subtag { color: var(--muted); }
			.hero { margin-bottom: 5rem; }
			.grid { display: grid; gap: 1rem; }
			.card { display: block; padding: 1.25rem; background: var(--card); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: border-color 0.2s; }
			.card:hover { border-color: var(--accent); }
			.tags { display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
			.tag { font-size: 0.75rem; padding: 0.25rem 0.5rem; background: var(--border); border-radius: 4px; color: var(--muted); }
			.note { color: var(--muted); font-size: 0.875rem; margin-top: 1rem; }
			a { color: var(--accent); text-decoration: none; }
			a:hover { text-decoration: underline; }
			footer { border-top: 1px solid var(--border); padding-top: 2rem; color: var(--muted); font-size: 0.875rem; }
		</style>
	</body>
</html>
